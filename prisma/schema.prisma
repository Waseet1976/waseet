generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL") // Décommenter avec Supabase connection pooler
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  AGENCY
  AGENT
  DEAL_FINDER
}

enum PipelineStage {
  DECLARED
  VALIDATED
  IN_REVIEW
  MANDATE_SIGNED
  COMPROMISE_SIGNED
  DEED_SIGNED
  COMMISSION_VALIDATED
  COMMISSION_PAID
}

enum AdminStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum CommissionStatus {
  ESTIMATED
  VALIDATED
  PAID
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  REJECTED
}

enum ContractType {
  MANDATE
  COMPROMISE
  DEED
  APPORTEUR_AGREEMENT
}

// ============================================================
// MODELS
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  country      String?
  role         Role     @default(AGENT)
  referralCode String   @unique @default(cuid())
  referredById String?
  isActive     Boolean  @default(true)
  ghlContactId String?
  agencyId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  agency            Agency?        @relation(fields: [agencyId], references: [id])
  referredBy        User?          @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]         @relation("Referrals")
  agentProfile      Agent?
  declaredProps     Property[]     @relation("DeclaredBy")
  changedLogs       PipelineLog[]  @relation("ChangedBy")
  contracts         Contract[]
  notifications     Notification[]
  referralsMade     Referral[]     @relation("Referrer")
  referralsReceived Referral[]     @relation("Referred")
  commissions       Commission[]   @relation("ApporteurCommissions")

  @@index([agencyId])
  @@index([referredById])
  @@map("users")
}

model Agency {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  city             String?
  country          String?
  commissionRate   Float    @default(2.5)
  apporteurShare   Float    @default(40)
  isActive         Boolean  @default(true)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  users       User[]
  agents      Agent[]
  properties  Property[]
  commissions Commission[]

  @@map("agencies")
}

model Agent {
  id        String   @id @default(cuid())
  userId    String   @unique
  photo     String?
  fonction  String?
  agencyId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency             Agency?    @relation(fields: [agencyId], references: [id])
  assignedProperties Property[] @relation("AssignedAgent")

  @@index([agencyId])
  @@map("agents")
}

model Property {
  id             String   @id @default(cuid())
  reference      String   @unique @default(cuid())
  country        String?
  city           String?
  neighborhood   String?
  address        String?
  postalCode     String?
  latitude       Float?
  longitude      Float?
  propertyType   String?
  surfaceSqm     Float?
  estimatedPrice Float?
  roomsCount     Int?
  description    String?
  photos         String[]
  documents      String[]

  // Propriétaire
  ownerName  String?
  ownerPhone String?
  ownerEmail String?

  // Relations déclarant / agence / agent
  declaredById    String
  agencyId        String?
  assignedAgentId String?

  // Dates pipeline
  declaredAt         DateTime  @default(now())
  mandateSignedAt    DateTime?
  compromiseSignedAt DateTime?
  deedSignedAt       DateTime?

  // Pipeline & statuts
  pipelineStage PipelineStage @default(DECLARED)
  adminStatus   AdminStatus   @default(PENDING)

  // Dédoublonnage
  duplicateKey String?
  isDuplicate  Boolean @default(false)
  isPriority   Boolean @default(false)

  // Divers
  internalNotes    String?
  ghlOpportunityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  declaredBy    User          @relation("DeclaredBy", fields: [declaredById], references: [id])
  agency        Agency?       @relation(fields: [agencyId], references: [id])
  assignedAgent Agent?        @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  commissions   Commission[]
  pipelineLogs  PipelineLog[]
  contracts     Contract[]

  @@index([agencyId])
  @@index([declaredById])
  @@index([assignedAgentId])
  @@index([pipelineStage])
  @@index([adminStatus])
  @@index([duplicateKey])
  @@map("properties")
}

model Commission {
  id              String           @id @default(cuid())
  propertyId      String
  apporteurId     String
  agencyId        String?
  estimatedAmount Float?
  validatedAmount Float?
  status          CommissionStatus @default(ESTIMATED)
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  apporteur User     @relation("ApporteurCommissions", fields: [apporteurId], references: [id])
  agency    Agency?  @relation(fields: [agencyId], references: [id])

  @@index([propertyId])
  @@index([apporteurId])
  @@index([agencyId])
  @@map("commissions")
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  bonusAmount Float    @default(0)
  bonusPaid   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referred User @relation("Referred", fields: [referredId], references: [id])

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@map("referrals")
}

model PipelineLog {
  id          String        @id @default(cuid())
  propertyId  String
  stage       PipelineStage
  changedById String?
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  changedBy User?    @relation("ChangedBy", fields: [changedById], references: [id])

  @@index([propertyId])
  @@index([changedById])
  @@map("pipeline_logs")
}

model Contract {
  id                 String         @id @default(cuid())
  propertyId         String
  userId             String
  type               ContractType
  status             ContractStatus @default(DRAFT)
  hellosignRequestId String?
  templateUsed       String?
  signedAt           DateTime?
  documentUrl        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([propertyId])
  @@index([userId])
  @@map("contracts")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
